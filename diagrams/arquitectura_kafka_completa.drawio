<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="Diagrama de Arquitectura Completa">
    <mxGraphModel dx="1000" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Nodos Principales -->
        <mxCell id="kafka" value="Kafka Cluster" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="350" y="300" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Topics -->
        <mxCell id="t1" value="account-movements" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="100" y="400" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="debit-payment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="350" y="400" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="yanki-payment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="600" y="400" width="120" height="30" as="geometry" />
        </mxCell>

        <!-- Servicios -->
        <mxCell id="mov_svc" value="Movement Service" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="500" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="acc_svc" value="Account Service" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="475" y="500" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="deb_svc" value="Debit Card Service" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="600" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="yank_svc" value="Yanki Service" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="600" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- Relaciones Kafka -->
        <mxCell id="e_k1" edge="1" parent="1" source="kafka" target="t1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_k2" edge="1" parent="1" source="kafka" target="t2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_k3" edge="1" parent="1" source="kafka" target="t3"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Relaciones Consumidores -->
        <mxCell id="e_c1" edge="1" parent="1" source="t1" target="mov_svc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_c2" edge="1" parent="1" source="t1" target="acc_svc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_c3" edge="1" parent="1" source="t2" target="acc_svc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_c4" edge="1" parent="1" source="t3" target="acc_svc"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Relaciones Productores -->
        <mxCell id="e_p1" edge="1" parent="1" source="deb_svc" target="t2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_p2" edge="1" parent="1" source="yank_svc" target="t3"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
