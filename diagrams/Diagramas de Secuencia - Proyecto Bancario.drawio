        <mxCell id="JSOgn54_lJlMQQxcyxIB-2" parent="JSOgn54_lJlMQQxcyxIB-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;h3 data-path-to-node=&quot;11&quot;&gt;&lt;font style=&quot;font-size: 40px;&quot;&gt;Pago con Tarjeta de Crédito (Integración Credit-Account)&lt;/font&gt;&lt;/h3&gt;&lt;p data-path-to-node=&quot;12&quot;&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="30" width="1540" x="50" y="30" as="geometry" />
        </mxCell>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    participant U as Cliente\n    participant CS as CreditServiceImpl\n    participant Repo as CreditRepository\n    participant AC as AccountClient\n    participant Red as Redis Cache\n\n    U-&gt;&gt;CS: POST /credits/{id}/payment (accountId, amount)\n    CS-&gt;&gt;Repo: findById(creditId)\n    Repo--&gt;&gt;CS: Mono&lt;Credit&gt;\n    \n    Note over CS: Validación: ¿Crédito existe?\n    \n    CS-&gt;&gt;AC: getAccountById(accountId)\n    AC--&gt;&gt;CS: Mono&lt;Account&gt;\n    \n    Note over CS: Validación de negocio (validatePayment)\n    alt Saldo cuenta &lt; Amount || Amount &gt; Deuda\n        CS--&gt;&gt;U: 400 Bad Request (Insufficient/Exceeds)\n    else Pago válido\n        CS-&gt;&gt;AC: withdraw(accountId, request)\n        AC--&gt;&gt;CS: Mono&lt;Account&gt; (Retiro exitoso)\n        \n        Note over CS: Aplicar pago (applyPayment)\n        CS-&gt;&gt;CS: newBalance = outstanding - amount\n        CS-&gt;&gt;Repo: save(credit)\n        CS-&gt;&gt;Red: delete(\&quot;credit:\&quot; + id)\n        \n        CS--&gt;&gt;U: 200 OK (Credit updated)\n    end&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="77MBp-sbQ6NLid6Jx6jz-0">
          <mxCell connectable="0" parent="JSOgn54_lJlMQQxcyxIB-1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
