        </mxCell>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    participant U as Cliente\n    participant MS as Movement Service\n    participant DB as MongoDB\n    participant Cache as Redis\n\n    U-&gt;&gt;MS: GET /movements/last-ten/{productId}\n    MS-&gt;&gt;Cache: Check last movements (for performance)\n    alt Cache Hit\n        Cache--&gt;&gt;MS: Data\n    else Cache Miss\n        MS-&gt;&gt;DB: FindByProductId (Sorted by date DESC)\n        DB--&gt;&gt;MS: List&lt;Movement&gt;\n        MS-&gt;&gt;MS: Stream().limit(10).collect()\n        MS-&gt;&gt;Cache: Save 10 movements\n    end\n    MS--&gt;&gt;U: 200 OK (List of 10)&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="jHI-atEvrU79qDl_ZI7x-2">
