        </mxCell>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    participant U as Cliente\n    participant YS as YankiServiceImpl\n    participant DS as DebitCardClient\n    participant Repo as YankiRepository\n\n    U-&gt;&gt;YS: associateDebitCard(phone, cardNumber)\n    \n    Note over YS: Consulta síncrona (REST)\n    YS-&gt;&gt;DS: getDebitCardByNumber(cardNumber)\n    \n    alt Tarjeta no encontrada o inválida\n        DS--&gt;&gt;YS: 404 Not Found / Error\n        YS--&gt;&gt;U: 400 Bad Request\n    else Tarjeta válida\n        DS--&gt;&gt;YS: DebitCard (DTO)\n        \n        YS-&gt;&gt;Repo: findByPhoneNumber(phone)\n        alt Wallet no existe\n            YS--&gt;&gt;U: 404 Wallet Not Found\n        else Wallet encontrada\n            YS-&gt;&gt;YS: wallet.setCardNumber(cardNumber)\n            YS-&gt;&gt;Repo: save(wallet)\n            YS--&gt;&gt;U: 200 OK (Asociación Exitosa)\n        end\n    end&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="4eU2kTcBbiFS43X1pLrF-15">
