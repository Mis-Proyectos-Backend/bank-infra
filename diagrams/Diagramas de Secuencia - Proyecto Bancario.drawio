        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="UJeLyvPqEJkzIQxOqj2V-17" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=40;" value="Yanki Transfer" vertex="1">
          <mxGeometry height="30" width="1600" x="20" y="70" as="geometry" />
        </mxCell>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    participant U as Cliente\n    participant YS as YankiServiceImpl\n    participant KP as YankiPaymentProducer (Kafka)\n    participant AS as AccountService (Consumer)\n    participant Repo as AccountRepository\n    participant MS as MovementService (Consumer)\n\n    U-&gt;&gt;YS: POST /api/yanki/transfer (phone, targetAccount, amount)\n    \n    Note over YS: 1. Validación de origen\n    YS-&gt;&gt;YS: validateWallet(phone)\n    \n    Note over YS: 2. Emisión de evento de transferencia\n    YS-&gt;&gt;KP: send(YankiTransferEvent)\n    \n    Note over AS: 3. AccountService recibe evento\n    KP-&gt;&gt;AS: Consume(YankiTransferEvent)\n    \n    Note over AS: 4. Ejecución contable\n    AS-&gt;&gt;AS: validateAccounts(source, target)\n    AS-&gt;&gt;AS: executeTransfer(amount)\n    AS-&gt;&gt;Repo: save(updatedAccounts)\n    \n    Note over AS: 5. Notificación de movimiento\n    AS-&gt;&gt;AS: send(MovementEvent)\n    \n    Note over MS: 6. MovementService recibe movimiento\n    AS-&gt;&gt;MS: Consume(MovementEvent)\n    MS-&gt;&gt;MS: save(movement)\n    \n    AS--&gt;&gt;YS: (Eventual Success)&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="_nDzS6JHLXdoWzdTour3-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
            <mxGeometry height="651" width="1330" as="geometry" />
          </mxCell>
